# Ignore Python cache
__pycache__/
*.pyc
*.pyo

# Ignore virtual environment folders
venv/
env/

# Ignore Flask instance folder (runtime files, local DB, uploads, etc.)
instance/

# Ignore SQLite database files if placed outside instance
*.db

# Ignore migrations (optional, if you don’t want to track them)
migrations/

# Ignore IDE/project settings
.vscode/
.idea/